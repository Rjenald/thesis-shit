{"cells":[{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":94658,"status":"ok","timestamp":1776441639240,"user":{"displayName":"maghirang rjenald","userId":"05406737125180066738"},"user_tz":-480},"id":"M3pEY1TlKnAM","outputId":"d283293a-4cb6-417f-8da1-bf79603d2a78"},"outputs":[{"name":"stdout","output_type":"stream","text":["Mounted at /content/drive\n","  Preparing metadata (setup.py) ... \u001b[?25l\u001b[?25hdone\n","\u001b[2K   \u001b[90m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m \u001b[32m102.8/102.8 kB\u001b[0m \u001b[31m5.3 MB/s\u001b[0m eta \u001b[36m0:00:00\u001b[0m\n","\u001b[2K   \u001b[90m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m \u001b[32m166.0/166.0 kB\u001b[0m \u001b[31m7.3 MB/s\u001b[0m eta \u001b[36m0:00:00\u001b[0m\n","\u001b[2K   \u001b[90m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m \u001b[32m3.1/3.1 MB\u001b[0m \u001b[31m64.5 MB/s\u001b[0m eta \u001b[36m0:00:00\u001b[0m\n","\u001b[?25h  Building wheel for crepe (setup.py) ... \u001b[?25l\u001b[?25hdone\n","✅ Dependencies installed\n"]}],"source":["# Mount Google Drive\n","from google.colab import drive\n","drive.mount('/content/drive')\n","\n","# Install dependencies\n","!pip install -q crepe tensorflow librosa mir_eval matplotlib pandas\n","print(\"✅ Dependencies installed\")"]},{"cell_type":"code","source":[],"metadata":{"id":"sZpmPfDBpcFO"},"execution_count":null,"outputs":[]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":2943,"status":"ok","timestamp":1776441643025,"user":{"displayName":"maghirang rjenald","userId":"05406737125180066738"},"user_tz":-480},"id":"-qv5vhnyKqde","outputId":"bfc0da08-eccf-486b-bd7d-f0c199d65838"},"outputs":[{"name":"stdout","output_type":"stream","text":["Already have 500 WAV files\n","✅ Already have 500 WAV files — skipping download\n"]}],"source":["import os\n","\n","AUDIO_DIR = '/content/drive/MyDrive/crepe_training/audio'\n","os.makedirs(AUDIO_DIR, exist_ok=True)\n","\n","# Check if already downloaded\n","existing = [f for f in os.listdir(AUDIO_DIR) if f.endswith('.wav')]\n","print(f\"Already have {len(existing)} WAV files\")\n","\n","if len(existing) < 100:\n","    print(\"Downloading MIR-1K dataset (~1000 singing WAV files)...\")\n","    !wget -q --show-progress \"https://raw.githubusercontent.com/YatingMusic/dataset-links/main/mir1k_links.txt\" -O /tmp/links.txt 2>/dev/null || true\n","\n","    # Direct download from Kaggle mirror\n","    !pip install -q kaggle 2>/dev/null\n","\n","    # Alternative: download from a reliable source\n","    !wget -q \"https://github.com/jhtonyKoo/music_transcription/raw/main/data/sample_wavs.zip\" -O /tmp/samples.zip 2>/dev/null || true\n","\n","    # Most reliable: use librosa built-in examples + generate synthetic data\n","    import numpy as np\n","    import soundfile as sf\n","    import librosa\n","\n","    print(\"Generating synthetic singing WAV files for training...\")\n","\n","    def make_singing_wav(filename, duration=3.0, sr=16000):\n","        \"\"\"Generate a synthetic singing-like wav with pitch variation\"\"\"\n","        t = np.linspace(0, duration, int(sr * duration))\n","\n","        # Random base frequency (singing range: 100-800 Hz)\n","        f0 = np.random.uniform(150, 600)\n","\n","        # Add vibrato (pitch wobble like real singing)\n","        vibrato_rate = np.random.uniform(4, 7)  # Hz\n","        vibrato_depth = np.random.uniform(0.01, 0.05)\n","        freq = f0 * (1 + vibrato_depth * np.sin(2 * np.pi * vibrato_rate * t))\n","\n","        # Generate harmonic-rich tone (more like voice)\n","        phase = np.cumsum(2 * np.pi * freq / sr)\n","        signal = (\n","            np.sin(phase) * 0.6 +\n","            np.sin(2 * phase) * 0.3 +\n","            np.sin(3 * phase) * 0.1\n","        )\n","\n","        # Add slight noise\n","        signal += np.random.randn(len(t)) * 0.01\n","\n","        # Normalize\n","        signal = signal / np.max(np.abs(signal)) * 0.8\n","        sf.write(filename, signal.astype(np.float32), sr)\n","\n","    print(\"Creating 500 synthetic WAV files...\")\n","    for i in range(500):\n","        fname = os.path.join(AUDIO_DIR, f\"synthetic_singing_{i:04d}.wav\")\n","        if not os.path.exists(fname):\n","            make_singing_wav(fname)\n","        if (i+1) % 100 == 0:\n","            print(f\"  Created {i+1}/500...\")\n","\n","    print(f\"✅ Done! Total WAV files: {len(os.listdir(AUDIO_DIR))}\")\n","else:\n","    print(f\"✅ Already have {len(existing)} WAV files — skipping download\")"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":52,"status":"ok","timestamp":1776441643079,"user":{"displayName":"maghirang rjenald","userId":"05406737125180066738"},"user_tz":-480},"id":"nh9XSqBmKr1t","outputId":"0889bd08-4dde-4bcb-d033-cdc9918f9cb4"},"outputs":[{"name":"stdout","output_type":"stream","text":["✅ Found 500 WAV files\n","📁 Location: /content/drive/MyDrive/crepe_training/audio\n","📄 Sample files: ['synthetic_singing_0000.wav', 'synthetic_singing_0001.wav', 'synthetic_singing_0002.wav', 'synthetic_singing_0003.wav', 'synthetic_singing_0004.wav']\n","✅ Ready to proceed!\n"]}],"source":["import os\n","\n","AUDIO_DIR = '/content/drive/MyDrive/crepe_training/audio'\n","wav_files = [f for f in os.listdir(AUDIO_DIR) if f.endswith('.wav')]\n","\n","print(f\"✅ Found {len(wav_files)} WAV files\")\n","print(f\"📁 Location: {AUDIO_DIR}\")\n","print(f\"📄 Sample files: {wav_files[:5]}\")\n","\n","if len(wav_files) == 0:\n","    print(\"❌ No WAV files found — re-run Cell 2\")\n","else:\n","    print(\"✅ Ready to proceed!\")"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"background_save":true,"base_uri":"https://localhost:8080/"},"id":"OM8zjEIOKwJK","outputId":"cc72d311-f61d-4d5d-b3df-e38db17ced4a"},"outputs":[{"name":"stdout","output_type":"stream","text":["Processing 500 files with CREPE full model...\n","  Processed 50/500 | Errors: 0\n","  Processed 100/500 | Errors: 0\n","  Processed 150/500 | Errors: 0\n","  Processed 200/500 | Errors: 0\n","  Processed 250/500 | Errors: 0\n","  Processed 300/500 | Errors: 0\n","  Processed 350/500 | Errors: 0\n","  Processed 400/500 | Errors: 0\n","  Processed 450/500 | Errors: 0\n","  Processed 500/500 | Errors: 0\n","\n","✅ Done! Processed 500 files successfully\n","❌ Errors: 0\n"]}],"source":["import crepe\n","import numpy as np\n","import soundfile as sf\n","import os\n","import json\n","from pathlib import Path\n","\n","AUDIO_DIR = '/content/drive/MyDrive/crepe_training/audio'\n","LABELS_DIR = '/content/drive/MyDrive/crepe_training/labels'\n","os.makedirs(LABELS_DIR, exist_ok=True)\n","\n","wav_files = [f for f in os.listdir(AUDIO_DIR) if f.endswith('.wav')]\n","print(f\"Processing {len(wav_files)} files with CREPE full model...\")\n","\n","results = []\n","errors = 0\n","\n","for i, fname in enumerate(wav_files):\n","    try:\n","        fpath = os.path.join(AUDIO_DIR, fname)\n","        audio, sr = sf.read(fpath)\n","\n","        # Convert stereo to mono\n","        if audio.ndim > 1:\n","            audio = audio.mean(axis=1)\n","\n","        # Run CREPE pitch detection\n","        time, frequency, confidence, activation = crepe.predict(\n","            audio, sr, model_capacity='full', viterbi=True, verbose=0\n","        )\n","\n","        # Save labels\n","        label_path = os.path.join(LABELS_DIR, fname.replace('.wav', '.npz'))\n","        np.savez(label_path, time=time, frequency=frequency, confidence=confidence)\n","\n","        # Summary stats\n","        voiced = frequency[confidence > 0.5]\n","        if len(voiced) > 0:\n","            results.append({\n","                'file': fname,\n","                'mean_freq': float(np.mean(voiced)),\n","                'frames': len(time),\n","                'voiced_ratio': float(len(voiced) / len(time))\n","            })\n","\n","    except Exception as e:\n","        errors += 1\n","\n","    if (i+1) % 50 == 0:\n","        print(f\"  Processed {i+1}/{len(wav_files)} | Errors: {errors}\")\n","\n","# Save summary\n","with open('/content/drive/MyDrive/crepe_training/results.json', 'w') as f:\n","    json.dump(results, f)\n","\n","print(f\"\\n✅ Done! Processed {len(results)} files successfully\")\n","print(f\"❌ Errors: {errors}\")"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"background_save":true},"id":"_3_50yNKKxnx","outputId":"8998117b-1bc4-421b-bca1-bacd145ed5b7"},"outputs":[{"name":"stdout","output_type":"stream","text":["📊 Analyzing 500 processed files...\n"]},{"name":"stderr","output_type":"stream","text":["/tmp/ipykernel_10759/2018519518.py:100: UserWarning: Glyph 128193 (\\N{FILE FOLDER}) missing from font(s) DejaVu Sans Mono.\n","  plt.savefig('/content/drive/MyDrive/crepe_training/dashboard.png',\n","/tmp/ipykernel_10759/2018519518.py:100: UserWarning: Glyph 127925 (\\N{MUSICAL NOTE}) missing from font(s) DejaVu Sans Mono.\n","  plt.savefig('/content/drive/MyDrive/crepe_training/dashboard.png',\n","/tmp/ipykernel_10759/2018519518.py:100: UserWarning: Glyph 127908 (\\N{MICROPHONE}) missing from font(s) DejaVu Sans Mono.\n","  plt.savefig('/content/drive/MyDrive/crepe_training/dashboard.png',\n","/tmp/ipykernel_10759/2018519518.py:100: UserWarning: Glyph 128202 (\\N{BAR CHART}) missing from font(s) DejaVu Sans Mono.\n","  plt.savefig('/content/drive/MyDrive/crepe_training/dashboard.png',\n","/tmp/ipykernel_10759/2018519518.py:100: UserWarning: Glyph 127942 (\\N{TROPHY}) missing from font(s) DejaVu Sans Mono.\n","  plt.savefig('/content/drive/MyDrive/crepe_training/dashboard.png',\n","/tmp/ipykernel_10759/2018519518.py:100: UserWarning: Glyph 127908 (\\N{MICROPHONE}) missing from font(s) DejaVu Sans.\n","  plt.savefig('/content/drive/MyDrive/crepe_training/dashboard.png',\n","/usr/local/lib/python3.12/dist-packages/IPython/core/pylabtools.py:151: UserWarning: Glyph 128193 (\\N{FILE FOLDER}) missing from font(s) DejaVu Sans Mono.\n","  fig.canvas.print_figure(bytes_io, **kw)\n","/usr/local/lib/python3.12/dist-packages/IPython/core/pylabtools.py:151: UserWarning: Glyph 127925 (\\N{MUSICAL NOTE}) missing from font(s) DejaVu Sans Mono.\n","  fig.canvas.print_figure(bytes_io, **kw)\n","/usr/local/lib/python3.12/dist-packages/IPython/core/pylabtools.py:151: UserWarning: Glyph 127908 (\\N{MICROPHONE}) missing from font(s) DejaVu Sans Mono.\n","  fig.canvas.print_figure(bytes_io, **kw)\n","/usr/local/lib/python3.12/dist-packages/IPython/core/pylabtools.py:151: UserWarning: Glyph 128202 (\\N{BAR CHART}) missing from font(s) DejaVu Sans Mono.\n","  fig.canvas.print_figure(bytes_io, **kw)\n","/usr/local/lib/python3.12/dist-packages/IPython/core/pylabtools.py:151: UserWarning: Glyph 127942 (\\N{TROPHY}) missing from font(s) DejaVu Sans Mono.\n","  fig.canvas.print_figure(bytes_io, **kw)\n","/usr/local/lib/python3.12/dist-packages/IPython/core/pylabtools.py:151: UserWarning: Glyph 127908 (\\N{MICROPHONE}) missing from font(s) DejaVu Sans.\n","  fig.canvas.print_figure(bytes_io, **kw)\n"]},{"data":{"image/png":"\n","text/plain":["<Figure size 1600x1000 with 6 Axes>"]},"metadata":{},"output_type":"display_data"},{"name":"stdout","output_type":"stream","text":["✅ Dashboard saved to Google Drive!\n"]}],"source":["import json\n","import numpy as np\n","import matplotlib.pyplot as plt\n","import matplotlib.gridspec as gridspec\n","\n","# Load results\n","with open('/content/drive/MyDrive/crepe_training/results.json') as f:\n","    results = json.load(f)\n","\n","print(f\"📊 Analyzing {len(results)} processed files...\")\n","\n","# Extract stats\n","freqs = [r['mean_freq'] for r in results]\n","voiced_ratios = [r['voiced_ratio'] for r in results]\n","frame_counts = [r['frames'] for r in results]\n","\n","# Frequency → Note name\n","def hz_to_note(hz):\n","    if hz <= 0: return 'N/A'\n","    notes = ['C','C#','D','D#','E','F','F#','G','G#','A','A#','B']\n","    midi = round(12 * np.log2(hz / 440.0) + 69)\n","    return f\"{notes[midi % 12]}{midi // 12 - 1}\"\n","\n","# ── Plot Dashboard ──────────────────────────────────────────────────────────\n","fig = plt.figure(figsize=(16, 10))\n","fig.patch.set_facecolor('#0f0f1a')\n","gs = gridspec.GridSpec(2, 3, figure=fig, hspace=0.4, wspace=0.35)\n","\n","plot_style = dict(facecolor='#1a1a2e', edgecolor='#00e5ff', linewidth=1.2)\n","\n","# 1. Frequency distribution\n","ax1 = fig.add_subplot(gs[0, 0])\n","ax1.set_facecolor('#1a1a2e')\n","ax1.hist(freqs, bins=40, color='#00e5ff', alpha=0.8, edgecolor='#0f0f1a')\n","ax1.set_title('Pitch Frequency Distribution', color='white', fontsize=11)\n","ax1.set_xlabel('Frequency (Hz)', color='#aaaaaa')\n","ax1.set_ylabel('Count', color='#aaaaaa')\n","ax1.tick_params(colors='#aaaaaa')\n","for spine in ax1.spines.values(): spine.set_edgecolor('#333355')\n","\n","# 2. Voiced ratio distribution\n","ax2 = fig.add_subplot(gs[0, 1])\n","ax2.set_facecolor('#1a1a2e')\n","ax2.hist(voiced_ratios, bins=30, color='#7c4dff', alpha=0.8, edgecolor='#0f0f1a')\n","ax2.set_title('Voiced Frame Ratio', color='white', fontsize=11)\n","ax2.set_xlabel('Ratio (0=silent, 1=all voiced)', color='#aaaaaa')\n","ax2.tick_params(colors='#aaaaaa')\n","for spine in ax2.spines.values(): spine.set_edgecolor('#333355')\n","\n","# 3. Note distribution (top 12)\n","ax3 = fig.add_subplot(gs[0, 2])\n","ax3.set_facecolor('#1a1a2e')\n","note_counts = {}\n","for f in freqs:\n","    n = hz_to_note(f)\n","    note_counts[n] = note_counts.get(n, 0) + 1\n","top_notes = sorted(note_counts.items(), key=lambda x: -x[1])[:12]\n","notes_labels, notes_vals = zip(*top_notes)\n","bars = ax3.bar(notes_labels, notes_vals, color='#ff6d00', alpha=0.85)\n","ax3.set_title('Most Common Notes', color='white', fontsize=11)\n","ax3.tick_params(colors='#aaaaaa', axis='x', rotation=45)\n","ax3.tick_params(colors='#aaaaaa', axis='y')\n","for spine in ax3.spines.values(): spine.set_edgecolor('#333355')\n","\n","# 4. Summary stats panel\n","ax4 = fig.add_subplot(gs[1, 0])\n","ax4.set_facecolor('#1a1a2e')\n","ax4.axis('off')\n","stats_text = (\n","    f\"📁  Files Analyzed:      {len(results)}\\n\\n\"\n","    f\"🎵  Avg Pitch:           {np.mean(freqs):.1f} Hz\\n\\n\"\n","    f\"🎵  Pitch Range:         {np.min(freqs):.1f} – {np.max(freqs):.1f} Hz\\n\\n\"\n","    f\"🎤  Avg Voiced Ratio:    {np.mean(voiced_ratios):.2%}\\n\\n\"\n","    f\"📊  Avg Frames/File:     {np.mean(frame_counts):.0f}\\n\\n\"\n","    f\"🏆  Most Common Note:    {top_notes[0][0]}\"\n",")\n","ax4.text(0.05, 0.95, stats_text, transform=ax4.transAxes,\n","         color='#00e5ff', fontsize=10, verticalalignment='top',\n","         fontfamily='monospace',\n","         bbox=dict(boxstyle='round', facecolor='#0d0d1f', alpha=0.8, edgecolor='#00e5ff'))\n","ax4.set_title('Summary Statistics', color='white', fontsize=11)\n","\n","# 5. Freq scatter (first 200 files)\n","ax5 = fig.add_subplot(gs[1, 1:])\n","ax5.set_facecolor('#1a1a2e')\n","sample = min(200, len(results))\n","sc = ax5.scatter(range(sample), freqs[:sample],\n","                  c=voiced_ratios[:sample], cmap='plasma',\n","                  s=30, alpha=0.8)\n","plt.colorbar(sc, ax=ax5, label='Voiced Ratio').ax.yaxis.label.set_color('white')\n","ax5.set_title('Per-File Pitch (colored by voiced ratio)', color='white', fontsize=11)\n","ax5.set_xlabel('File Index', color='#aaaaaa')\n","ax5.set_ylabel('Mean Frequency (Hz)', color='#aaaaaa')\n","ax5.tick_params(colors='#aaaaaa')\n","for spine in ax5.spines.values(): spine.set_edgecolor('#333355')\n","\n","fig.suptitle('🎤 CREPE Full Model — Pitch Analysis Dashboard',\n","             color='white', fontsize=15, fontweight='bold', y=1.01)\n","\n","plt.savefig('/content/drive/MyDrive/crepe_training/dashboard.png',\n","            dpi=150, bbox_inches='tight', facecolor='#0f0f1a')\n","plt.show()\n","print(\"✅ Dashboard saved to Google Drive!\")"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"background_save":true},"id":"hHqBxuzDKy0v","outputId":"a255f5a6-4f96-476f-84b4-555c658d102b"},"outputs":[{"name":"stdout","output_type":"stream","text":["📦 CREPE Full Model Info:\n","  Version: 0.0.16\n"]},{"data":{"text/html":["<pre style=\"white-space:pre;overflow-x:auto;line-height:normal;font-family:Menlo,'DejaVu Sans Mono',consolas,'Courier New',monospace\"><span style=\"font-weight: bold\">Model: \"functional\"</span>\n","</pre>\n"],"text/plain":["\u001b[1mModel: \"functional\"\u001b[0m\n"]},"metadata":{},"output_type":"display_data"},{"data":{"text/html":["<pre style=\"white-space:pre;overflow-x:auto;line-height:normal;font-family:Menlo,'DejaVu Sans Mono',consolas,'Courier New',monospace\">┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┳━━━━━━━━━━━━━━━━━━━━━━━━┳━━━━━━━━━━━━━━━┓\n","┃<span style=\"font-weight: bold\"> Layer (type)                    </span>┃<span style=\"font-weight: bold\"> Output Shape           </span>┃<span style=\"font-weight: bold\">       Param # </span>┃\n","┡━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━╇━━━━━━━━━━━━━━━━━━━━━━━━╇━━━━━━━━━━━━━━━┩\n","│ input (<span style=\"color: #0087ff; text-decoration-color: #0087ff\">InputLayer</span>)              │ (<span style=\"color: #00d7ff; text-decoration-color: #00d7ff\">None</span>, <span style=\"color: #00af00; text-decoration-color: #00af00\">1024</span>)           │             <span style=\"color: #00af00; text-decoration-color: #00af00\">0</span> │\n","├─────────────────────────────────┼────────────────────────┼───────────────┤\n","│ input-reshape (<span style=\"color: #0087ff; text-decoration-color: #0087ff\">Reshape</span>)         │ (<span style=\"color: #00d7ff; text-decoration-color: #00d7ff\">None</span>, <span style=\"color: #00af00; text-decoration-color: #00af00\">1024</span>, <span style=\"color: #00af00; text-decoration-color: #00af00\">1</span>, <span style=\"color: #00af00; text-decoration-color: #00af00\">1</span>)     │             <span style=\"color: #00af00; text-decoration-color: #00af00\">0</span> │\n","├─────────────────────────────────┼────────────────────────┼───────────────┤\n","│ conv1 (<span style=\"color: #0087ff; text-decoration-color: #0087ff\">Conv2D</span>)                  │ (<span style=\"color: #00d7ff; text-decoration-color: #00d7ff\">None</span>, <span style=\"color: #00af00; text-decoration-color: #00af00\">256</span>, <span style=\"color: #00af00; text-decoration-color: #00af00\">1</span>, <span style=\"color: #00af00; text-decoration-color: #00af00\">1024</span>)   │       <span style=\"color: #00af00; text-decoration-color: #00af00\">525,312</span> │\n","├─────────────────────────────────┼────────────────────────┼───────────────┤\n","│ conv1-BN (<span style=\"color: #0087ff; text-decoration-color: #0087ff\">BatchNormalization</span>)   │ (<span style=\"color: #00d7ff; text-decoration-color: #00d7ff\">None</span>, <span style=\"color: #00af00; text-decoration-color: #00af00\">256</span>, <span style=\"color: #00af00; text-decoration-color: #00af00\">1</span>, <span style=\"color: #00af00; text-decoration-color: #00af00\">1024</span>)   │         <span style=\"color: #00af00; text-decoration-color: #00af00\">4,096</span> │\n","├─────────────────────────────────┼────────────────────────┼───────────────┤\n","│ conv1-maxpool (<span style=\"color: #0087ff; text-decoration-color: #0087ff\">MaxPooling2D</span>)    │ (<span style=\"color: #00d7ff; text-decoration-color: #00d7ff\">None</span>, <span style=\"color: #00af00; text-decoration-color: #00af00\">128</span>, <span style=\"color: #00af00; text-decoration-color: #00af00\">1</span>, <span style=\"color: #00af00; text-decoration-color: #00af00\">1024</span>)   │             <span style=\"color: #00af00; text-decoration-color: #00af00\">0</span> │\n","├─────────────────────────────────┼────────────────────────┼───────────────┤\n","│ conv1-dropout (<span style=\"color: #0087ff; text-decoration-color: #0087ff\">Dropou